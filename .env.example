# ============================================
# Shopee商品ページ最適化ツール - 環境変数設定
# ============================================
# このファイルを .env にコピーして、各値を入力してください。
#   Mac/Linux: cp .env.example .env
#   Windows:   copy .env.example .env
# ============================================

# --- Amazon商品情報取得 (Rainforest API) ---
# https://www.rainforestapi.com/ でアカウント作成・APIキー取得
RAINFOREST_API_KEY=

# --- 画像テキスト英語化 (OpenAI) ---
# https://platform.openai.com/api-keys でAPIキー取得
# gpt-image-1.5 を使用（openai>=1.0 必須）
OPENAI_API_KEY=

# --- AI動画生成 (fal.ai) ---
# https://fal.ai/dashboard/keys でAPIキー取得
FAL_KEY=

# --- Google画像検索 (Serper.dev) [任意] ---
# https://serper.dev/ でAPIキー取得（月2,500回無料）
# 未設定の場合はDuckDuckGoにフォールバック
SERPER_API_KEY=

# --- Google Drive連携 (OAuth2) ---
# Google Cloud Console でOAuth2クライアントを作成
# リダイレクトURIに http://localhost:8080/auth/callback を追加すること
DRIVE_CLIENT_ID=
DRIVE_CLIENT_SECRET=
DRIVE_REFRESH_TOKEN=

# --- Google Drive アップロード先 ---
# アップロード先の親フォルダ（URLをそのまま貼り付けOK）
# 例: https://drive.google.com/drive/folders/XXXXX
DRIVE_PARENT_FOLDER_ID=

# --- Google Sheets連携 ---
# 書き込み先スプレッドシート（URLをそのまま貼り付けOK）
# 例: https://docs.google.com/spreadsheets/d/XXXXX/edit
SPREADSHEET_ID=

# --- Google Sheets サービスアカウント鍵 ---
# keys/service-account-key.json に配置済みなら変更不要
GCP_KEY_PATH=keys/service-account-key.json

# --- サーバーポート ---
PORT=8080
